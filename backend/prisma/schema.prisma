generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Branches {
  TURKCE
  MATEMATIK
  INGILIZCE
  BEDEN_EGITIMI
  RESIM
  MUZIK
  HAYAT_BILGISI
  FEN_BILGISI
  SATRANC
}

enum Grades {
  ELEMENTARY
  MIDDLE_HIGH
}

enum Days {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

// debate adding contstraint to the hours teacher hours

model schedule {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  
  teachers    teacher[]
  classrooms  classroom[]
  lessons     lesson[]
}

model teacher {
  id          String  @id @default(cuid())
  name        String
  hours       Int
  branch      Branches
  grade       Grades?
  lessons     lesson[]

  scheduleId  String
  schedule    schedule  @relation(fields: [scheduleId], references: [id])

  @@index([branch])
}

model classroom {
  id          String @id @default(cuid())
  name        String
  year        Int
  grade       Grades

  scheduleId  String
  schedule    schedule  @relation(fields: [scheduleId], references: [id])
  lessons     lesson[]
}

model lesson {
  id          String  @id @default(cuid())
  branch      Branches
  teacher_id  String
  class_id    String
  hour        Int
  day         Days
  scheduleId  String

  schedule    schedule  @relation(fields: [scheduleId], references: [id])
  teacher     teacher @relation(fields: [teacher_id], references: [id])
  classroom   classroom @relation(fields: [class_id], references: [id])

  @@unique([scheduleId, teacher_id, day, hour])
  @@unique([scheduleId, class_id, day, hour])

  @@index([teacher_id])
  @@index([class_id])
  @@index([day, hour])
  @@index([scheduleId])
}